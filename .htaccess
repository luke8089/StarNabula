# ═══════════════════════════════════════════════════════════════
#  StarNabula — Apache .htaccess
#  https://starnabula.tech
#  Covers: HTTPS · non-www · security headers · compression ·
#          caching · MIME types · bot blocking · error pages
# ═══════════════════════════════════════════════════════════════

Options -Indexes -MultiViews -ExecCGI
ServerSignature Off

# ────────────────────────────────────────────────────────────────
#  1. REDIRECTS & URL CANONICALISATION
# ────────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS (handles both direct and proxy/load-balancer)
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Hide index.html — redirect /index.html → /
  RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  # Force non-www  (www → starnabula.tech)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Remove trailing slash (except root)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} (.+)/$
  RewriteRule ^ %1 [R=301,L]

  # Clean URLs — serve .html without the extension
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ────────────────────────────────────────────────────────────────
#  2. SECURITY HEADERS
# ────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>

  # HSTS — 2 years, includeSubDomains, submit to preload list
  Header always set Strict-Transport-Security \
    "max-age=63072000; includeSubDomains; preload" \
    "expr=%{HTTPS} == 'on'"

  # Clickjacking — only allow framing by same origin
  Header always set X-Frame-Options "SAMEORIGIN"

  # Block MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # XSS protection (legacy IE/Edge)
  Header always set X-XSS-Protection "1; mode=block"

  # Referrer policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions policy — disable unused hardware APIs
  Header always set Permissions-Policy \
    "accelerometer=(), camera=(), display-capture=(), \
     fullscreen=(self), geolocation=(self), gyroscope=(), \
     magnetometer=(), microphone=(), payment=(), usb=()"

  # Content Security Policy
  # frame-src * allows portfolio live iframe previews of client sites
  Header always set Content-Security-Policy \
    "default-src 'self'; \
     script-src 'self' \
       https://cdnjs.cloudflare.com \
       https://www.googletagmanager.com \
       https://www.google-analytics.com \
       https://api.web3forms.com; \
     style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
     font-src 'self' https://fonts.gstatic.com data:; \
     img-src 'self' data: https: blob:; \
     frame-src *; \
     connect-src 'self' \
       https://api.web3forms.com \
       https://www.google-analytics.com \
       https://stats.g.doubleclick.net; \
     object-src 'none'; \
     base-uri 'self'; \
     form-action 'self' https://api.web3forms.com; \
     upgrade-insecure-requests;"

  # Cross-Origin policies
  Header always set Cross-Origin-Opener-Policy  "same-origin-allow-popups"
  Header always set Cross-Origin-Resource-Policy "cross-origin"

  # Remove server fingerprinting headers
  Header always unset Server
  Header always unset X-Powered-By
  Header always unset X-AspNet-Version
  Header always unset X-AspNetMvc-Version

  # CORS — allow fonts to load from any origin
  <FilesMatch "\.(ttf|otf|eot|woff|woff2)$">
    Header always set Access-Control-Allow-Origin "*"
  </FilesMatch>

</IfModule>

# ────────────────────────────────────────────────────────────────
#  3. GZIP / DEFLATE COMPRESSION
# ────────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>

  AddOutputFilterByType DEFLATE \
    text/html text/plain text/xml text/css text/javascript \
    application/javascript application/x-javascript \
    application/json application/ld+json application/manifest+json \
    application/xml application/xhtml+xml \
    image/svg+xml image/x-icon \
    font/ttf font/otf font/woff font/woff2 \
    application/font-woff application/font-woff2 application/x-font-ttf

  # Fix for old Netscape & IE bugs
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html

  Header append Vary Accept-Encoding

</IfModule>

# ────────────────────────────────────────────────────────────────
#  4. BROWSER CACHING — mod_expires
# ────────────────────────────────────────────────────────────────
<IfModule mod_expires.c>

  ExpiresActive On
  ExpiresDefault "access plus 1 month"

  # HTML — always fresh
  ExpiresByType text/html                      "access plus 0 seconds"

  # CSS & JS — 1 year (use query-string versioning or hash for updates)
  ExpiresByType text/css                       "access plus 1 year"
  ExpiresByType application/javascript         "access plus 1 year"
  ExpiresByType text/javascript                "access plus 1 year"
  ExpiresByType application/x-javascript      "access plus 1 year"

  # Images — 1 year
  ExpiresByType image/png                      "access plus 1 year"
  ExpiresByType image/jpg                      "access plus 1 year"
  ExpiresByType image/jpeg                     "access plus 1 year"
  ExpiresByType image/gif                      "access plus 1 year"
  ExpiresByType image/webp                     "access plus 1 year"
  ExpiresByType image/avif                     "access plus 1 year"
  ExpiresByType image/svg+xml                  "access plus 1 year"
  ExpiresByType image/x-icon                   "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon      "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/ttf                       "access plus 1 year"
  ExpiresByType font/otf                       "access plus 1 year"
  ExpiresByType font/woff                      "access plus 1 year"
  ExpiresByType font/woff2                     "access plus 1 year"
  ExpiresByType application/font-woff          "access plus 1 year"
  ExpiresByType application/font-woff2         "access plus 1 year"
  ExpiresByType application/x-font-ttf        "access plus 1 year"

  # Data — no cache
  ExpiresByType application/json               "access plus 0 seconds"
  ExpiresByType application/ld+json           "access plus 0 seconds"
  ExpiresByType application/xml                "access plus 0 seconds"
  ExpiresByType text/xml                       "access plus 0 seconds"

  # Manifest
  ExpiresByType application/manifest+json      "access plus 1 week"
  ExpiresByType text/cache-manifest           "access plus 0 seconds"

</IfModule>

# ────────────────────────────────────────────────────────────────
#  5. CACHE-CONTROL HEADERS (fine-grained)
# ────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>

  # HTML — never cache
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma         "no-cache"
    Header set Expires        0
  </FilesMatch>

  # Static assets — immutable for 1 year
  <FilesMatch "\.(css|js|mjs|png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Manifest — 1 week
  <FilesMatch "\.(webmanifest|manifest)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # JSON / XML data — no cache
  <FilesMatch "\.(json|xml)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

</IfModule>

# ────────────────────────────────────────────────────────────────
#  6. MIME TYPES
# ────────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType application/javascript              .js .mjs
  AddType text/css                            .css
  AddType image/svg+xml                       .svg .svgz
  AddType image/webp                          .webp
  AddType image/avif                          .avif
  AddType font/woff                           .woff
  AddType font/woff2                          .woff2
  AddType font/ttf                            .ttf
  AddType font/otf                            .otf
  AddType application/manifest+json           .webmanifest
  AddType application/ld+json                 .jsonld
  AddType text/cache-manifest                 .appcache
  AddEncoding gzip                            .svgz
</IfModule>

# ────────────────────────────────────────────────────────────────
#  7. CHARACTER ENCODING
# ────────────────────────────────────────────────────────────────
AddDefaultCharset UTF-8
<IfModule mod_mime.c>
  AddCharset UTF-8 .html .htm .css .js .mjs .json .xml .txt .rss .atom .webmanifest
</IfModule>

# ────────────────────────────────────────────────────────────────
#  8. ETAG — disable for consistent load-balanced behaviour
# ────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# ────────────────────────────────────────────────────────────────
#  9. BLOCK MALICIOUS BOTS & SCRAPERS
# ────────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} \
    (AhrefsBot|MJ12bot|DotBot|SemrushBot|BLEXBot|MegaIndex| \
     PetalBot|DataForSeoBot|Bytespider|Scrapy|masscan|sqlmap| \
     nikto|python-requests|libwww-perl|zgrab|Go-http-client/1) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# ────────────────────────────────────────────────────────────────
#  10. HOTLINK PROTECTION (images & fonts)
# ────────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https://(www\.)?starnabula\.tech [NC]
  RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
  RewriteCond %{HTTP_REFERER} !^https?://127\.0\.0\.1 [NC]
  RewriteRule \.(png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2)$ - [F,NC,L]
</IfModule>

# ────────────────────────────────────────────────────────────────
#  11. BLOCK SENSITIVE FILES
# ────────────────────────────────────────────────────────────────
<FilesMatch "(^#.*#|\.(bak|conf|dist|env|fla|in[ci]|log|orig|psd|sh|sql|sw[op]|swp)|~)$">
  Require all denied
</FilesMatch>

<Files ".env">
  Require all denied
</Files>

<Files ".htaccess">
  Require all denied
</Files>

<Files ".gitignore">
  Require all denied
</Files>

<Files "*.log">
  Require all denied
</Files>

# ────────────────────────────────────────────────────────────────
#  12. RESTRICT HTTP METHODS
# ────────────────────────────────────────────────────────────────
<LimitExcept GET POST HEAD OPTIONS>
  Require all denied
</LimitExcept>

# ────────────────────────────────────────────────────────────────
#  13. CUSTOM ERROR PAGES
# ────────────────────────────────────────────────────────────────
ErrorDocument 400 /index.html
ErrorDocument 401 /index.html
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html
ErrorDocument 503 /index.html
